# --- Runtime ---
ENVIRONMENT=dev
DEBUG=true

# --- API ---
API_V1_PREFIX=/api/v1
# Comma-separated origins. Use a real list in prod, * is dev-only.
CORS_ORIGINS=["*"]

# --- Database ---
# Inside docker-compose the host is `db`. Outside the stack, use localhost.
DATABASE_URL=postgresql+asyncpg://softglow:softglow@db:5432/softglow
DB_ECHO=false

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-prod-please-this-is-only-for-dev
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Postgres (used by docker-compose `db` service) ---
POSTGRES_USER=softglow
POSTGRES_PASSWORD=softglow
POSTGRES_DB=softglow
